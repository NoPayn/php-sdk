{
    "name": "nopayn/sdk",
    "description": "Official PHP SDK for the NoPayn Payment Gateway",
    "type": "library",
    "license": "MIT",
    "keywords": ["nopayn", "payment", "gateway", "sdk", "hpp"],
    "homepage": "https://github.com/NoPayn/php-sdk",
    "authors": [
        {
            "name": "Cost+",
            "homepage": "https://costplus.io"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10"
    },
    "autoload": {
        "psr-4": {
            "NoPayn\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NoPayn\\Tests\\": "tests/"
        }
    }
}
